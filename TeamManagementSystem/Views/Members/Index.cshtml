@model TeamManagementSystem.Web.ViewModels.Members.OrganizationMembersVm
@using TeamManagementSystem.Web.Models
@{
    ViewData["Title"] = "Members — " + Model.OrganizationName;
    var canManage = (bool)(ViewData["CanManage"] ?? false);
    var lastInviteLink = TempData["LastInviteLink"] as string;
}

<div class="tms-page tms-page--wide">
    <a asp-controller="Organizations" asp-action="Details" asp-route-id="@Model.OrganizationId" class="tms-back">
        <partial name="_TmsBackIcon" />
        Back to organization
    </a>

    <header class="tms-hero">
        <h1 class="tms-title">Members</h1>
        <p class="tms-subtitle">@Model.OrganizationName</p>
    </header>

    <hr class="tms-divider" />

    <div class="tms-card">
        <h2 class="tms-card__title">Current members</h2>
        <div class="tms-table-wrap">
            <table class="table tms-table table-sm">
                <thead>
                    <tr><th>Name</th><th>Email</th><th>Role</th><th>Joined</th></tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Members)
                    {
                        <tr>
                            <td><strong>@m.DisplayName</strong></td>
                            <td>@m.Email</td>
                            <td><span class="tms-badge">@m.Role</span></td>
                            <td class="tms-muted">@m.JoinedAtUtc.ToLocalTime().ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (canManage)
    {
        <div class="tms-card">
            <h2 class="tms-card__title">Invite new members</h2>
            <p class="tms-muted mb-3">Create an invitation link you can share. Anyone with the link can join this organization with the selected role.</p>

            @if (!string.IsNullOrEmpty(lastInviteLink))
            {
                <div class="alert alert-success">
                    <div><strong>Invite link created.</strong></div>
                    <div class="small"><code>@lastInviteLink</code></div>
                </div>
            }

            <form asp-action="CreateInvite" method="post" class="row g-2 mb-4">
                <input type="hidden" name="OrganizationId" value="@Model.OrganizationId" />
                <div class="col-md-4">
                    <select name="Role" class="form-select" required>
                        <option value="">Select role</option>
                        <option value="@WorkspaceRole.Lead">Manager</option>
                        <option value="@WorkspaceRole.Member">Member</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <input name="Email" class="form-control" placeholder="Invitee email (optional)" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">Create invite link</button>
                </div>
            </form>

            <h3 class="tms-card__title tms-card__title--sm">Pending invitations</h3>
            <div class="tms-table-wrap">
                <table class="table tms-table table-sm">
                    <thead>
                        <tr><th>Email (optional)</th><th>Role</th><th>Created</th><th>Expires</th></tr>
                    </thead>
                    <tbody>
                        @if (!Model.PendingInvites.Any())
                        {
                            <tr><td colspan="4" class="tms-muted">No pending invitations.</td></tr>
                        }
                        else
                        {
                            @foreach (var i in Model.PendingInvites)
                            {
                                <tr>
                                    <td>@(string.IsNullOrEmpty(i.Email) ? "(anyone with link)" : i.Email)</td>
                                    <td><span class="tms-badge">@i.Role</span></td>
                                    <td class="tms-muted">@i.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                                    <td class="tms-muted">@(i.ExpiresAtUtc?.ToLocalTime().ToString("g") ?? "Never")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
