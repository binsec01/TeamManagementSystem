@{
    ViewData["Title"] = "Invalid invitation";
}

<h2>Invitation not valid</h2>
<p class="text-muted">
    This organization invitation link is no longer valid. It may have expired, been revoked, or already been used.
</p>
<p>
    You can contact an organization admin to request a new invitation, or go back to your
    <a asp-controller="Organizations" asp-action="Index">organizations</a>.
</p>

