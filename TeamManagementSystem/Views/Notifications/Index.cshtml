@model IEnumerable<TeamManagementSystem.Web.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<div class="tms-page">
    <header class="tms-hero">
        <h1 class="tms-title">Notifications</h1>
        <div class="tms-toolbar">
            <form asp-action="MarkAllRead" method="post" class="mb-0">
                <button type="submit" class="btn btn-sm btn-secondary">Mark all as read</button>
            </form>
        </div>
    </header>

    <hr class="tms-divider" />

    @if (!Model.Any())
    {
        <div class="tms-empty">
            <p class="mb-0">No notifications.</p>
        </div>
    }
    else
    {
        <ul class="tms-list">
            @foreach (var n in Model)
            {
                <li class="tms-list-item @(n.IsRead ? "" : "tms-list-item--unread")">
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkRead" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@n.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary float-end">Mark read</button>
                        </form>
                    }
                    <a href="@(n.Url ?? "#")">@n.Message</a>
                    <br /><small class="tms-muted">@n.CreatedAtUtc.ToLocalTime().ToString("g") — @n.Type</small>
                </li>
            }
        </ul>
    }
</div>
