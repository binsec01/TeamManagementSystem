@model IEnumerable<OrganizationListVm>
@{
    ViewData["Title"] = "Organizations";
}

<h2>My Organizations</h2>
<p><a asp-controller="Onboarding" asp-action="Index" class="btn btn-primary">Set up your workspace</a></p>

<table class="table">
    <thead>
        <tr><th>Name</th><th>Roles</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Organization.Name</td>
                <td>@item.Role.ToString()</td>
                <td>
                    
                    <a asp-controller="Members" asp-action="Index" asp-route-organizationId="@item.Organization.Id">Members</a> |
                
                    @if (item.FirstTeamId is { } teamId)
                    {
                        <a asp-controller="Projects" asp-action="Index" asp-route-teamId="@teamId">Projects</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
