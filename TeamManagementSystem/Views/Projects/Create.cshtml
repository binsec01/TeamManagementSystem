@model ProjectCreateVm
@{
    ViewData["Title"] = "Create project";
    var teamId = (int)ViewData["TeamId"]!;
}

<h2>Create project</h2>
<form asp-action="Create" method="post">
    <input type="hidden" asp-for="TeamId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-floating mb-2">
        <input asp-for="Name" class="form-control" />
        <label asp-for="Name"></label>
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
    </div>
    <div class="row">
        <div class="col-md-6 form-floating mb-2">
            <input asp-for="StartDateUtc" class="form-control" type="date" />
            <label asp-for="StartDateUtc"></label>
        </div>
        <div class="col-md-6 form-floating mb-2">
            <input asp-for="DueDateUtc" class="form-control" type="date" />
            <label asp-for="DueDateUtc"></label>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" asp-route-teamId="@teamId" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
