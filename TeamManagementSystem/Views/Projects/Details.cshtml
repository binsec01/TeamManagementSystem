@model ProjectDetailsVm
@{
    ViewData["Title"] = Model.Name;
}

<h2>@Model.Name</h2>
<p>Team: <a asp-controller="Teams" asp-action="Details" asp-route-id="@Model.TeamId">@Model.TeamName</a></p>
@if (!string.IsNullOrEmpty(Model.Description)) { <p>@Model.Description</p> }
<p>
    <strong>Progress:</strong> @Model.OpenTaskCount open, @Model.CompletedTaskCount completed, @Model.OverdueTaskCount overdue
</p>
<p>
    <a asp-controller="Tasks" asp-action="List" asp-route-projectId="@Model.Id">List view</a> |
    <a asp-controller="Tasks" asp-action="Board" asp-route-projectId="@Model.Id">Board view</a> |
    <a asp-controller="Tasks" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-sm btn-primary">Add task</a>
</p>
<a asp-action="Index" asp-route-teamId="@Model.TeamId">Back to projects</a>
