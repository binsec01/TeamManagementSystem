@{
    ViewData["Title"] = "Reports";
    var orgId = (int)ViewData["OrganizationId"]!;
    var orgName = ViewData["OrganizationName"] as string ?? "";
}

<div class="tms-page">
    <a asp-controller="Organizations" asp-action="Details" asp-route-id="@orgId" class="tms-back">
        <partial name="_TmsBackIcon" />
        Back to organization
    </a>

    <header class="tms-hero">
        <h1 class="tms-title">Reports</h1>
        <p class="tms-subtitle">@orgName</p>
    </header>

    <hr class="tms-divider" />

    <ul class="tms-link-list">
        <li><a asp-action="ProjectProgress" asp-route-organizationId="@orgId">Project progress summary</a></li>
        <li><a asp-action="TeamWorkload" asp-route-organizationId="@orgId">Team workload report</a></li>
        <li><a asp-action="Activity" asp-route-organizationId="@orgId">Activity report</a></li>
    </ul>
</div>
