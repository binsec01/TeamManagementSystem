@model TaskBoardVm
@{
    ViewData["Title"] = "Board — " + Model.ProjectName;
    var projectId = (int)ViewData["ProjectId"]!;
    var canManage = (bool)ViewData["CanManage"]!;
}

<h2>@Model.ProjectName — Board</h2>
<p>
    <a asp-action="List" asp-route-projectId="@projectId">List view</a>
    @if (canManage) { <text> | </text> <a asp-action="Create" asp-route-projectId="@projectId" class="btn btn-sm btn-primary">Add task</a> }
</p>

<div class="row g-2">
    @foreach (var col in Model.Columns)
    {
        <div class="col-md">
            <div class="card">
                <div class="card-header py-2">@col.Key</div>
                <div class="card-body p-2">
                    @foreach (var task in col.Value)
                    {
                        <div class="border rounded p-2 mb-2 small">
                            <a asp-action="Details" asp-route-id="@task.Id">@task.Title</a>
                            <br />
                            <span class="badge bg-secondary">@task.Priority</span>
                            @if (task.DueDateUtc.HasValue) { <span class="text-muted">@task.DueDateUtc.Value.ToLocalTime().ToString("d")</span> }
                            @if (!string.IsNullOrEmpty(task.AssigneeName)) { <br /><span class="text-muted">@task.AssigneeName</span> }
                            @if (task.TagNames.Count > 0) { <br />@string.Join(", ", task.TagNames) }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
<a asp-controller="Projects" asp-action="Details" asp-route-id="@projectId">Back to project</a>
