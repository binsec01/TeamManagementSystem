@model TaskEditVm
@{
    ViewData["Title"] = "Edit task";
    var teamMembers = ViewData["TeamMembers"] as IEnumerable<TeamManagementSystem.Web.Models.Identity.ApplicationUser> ?? Enumerable.Empty<TeamManagementSystem.Web.Models.Identity.ApplicationUser>();
}

<div class="tms-page">
    <a asp-action="Details" asp-route-id="@Model.Id" class="tms-back">
        <partial name="_TmsBackIcon" />
        Back to task
    </a>

    <header class="tms-hero">
        <h1 class="tms-title">Edit task</h1>
    </header>

    <hr class="tms-divider" />

    <div class="tms-form-card">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ProjectId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-floating mb-2">
                <input asp-for="Title" class="form-control" />
                <label asp-for="Title"></label>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-2">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="row">
                <div class="col-md-4 form-floating mb-2">
                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<TeamManagementSystem.Web.Models.TaskStatus>()"></select>
                    <label asp-for="Status"></label>
                </div>
                <div class="col-md-4 form-floating mb-2">
                    <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<TeamManagementSystem.Web.Models.TaskPriority>()"></select>
                    <label asp-for="Priority"></label>
                </div>
                <div class="col-md-4 form-floating mb-2">
                    <input asp-for="DueDateUtc" class="form-control" type="date" />
                    <label asp-for="DueDateUtc"></label>
                </div>
            </div>
            <div class="mb-2">
                <label asp-for="AssigneeId" class="form-label"></label>
                <select asp-for="AssigneeId" class="form-select">
                    <option value="">— Unassigned —</option>
                    @foreach (var u in teamMembers)
                    { <option value="@u.Id">@(u.FullName ?? u.Email)</option> }
                </select>
            </div>
            <div class="form-floating mb-2">
                <input asp-for="TagNames" class="form-control" />
                <label asp-for="TagNames"></label>
            </div>
            <div class="tms-form-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
