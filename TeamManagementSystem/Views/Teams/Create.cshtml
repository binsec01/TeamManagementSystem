@{
    ViewData["Title"] = "Create team";
    var orgId = (int)ViewData["OrganizationId"]!;
}

<div class="tms-page">
    <a asp-action="Index" asp-route-organizationId="@orgId" class="tms-back">
        <partial name="_TmsBackIcon" />
        Back to teams
    </a>

    <header class="tms-hero">
        <h1 class="tms-title">Create team</h1>
    </header>

    <hr class="tms-divider" />

    <div class="tms-form-card">
        <form asp-action="Create" asp-route-organizationId="@orgId" method="post">
            <div class="form-floating mb-3">
                <input name="name" class="form-control" placeholder="Team name" required />
                <label>Team name</label>
            </div>
            <div class="tms-form-actions">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" asp-route-organizationId="@orgId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
