@model TeamManagementSystem.Web.Models.Team
@{
    ViewData["Title"] = Model.Name;
    var canManage = (bool)ViewData["CanManage"]!;
}

<div class="tms-page">
    <a asp-action="Index" asp-route-organizationId="@Model.OrganizationId" class="tms-back">
        <partial name="_TmsBackIcon" />
        Back to teams
    </a>

    <header class="tms-hero">
        <h1 class="tms-title">@Model.Name</h1>
        <div class="tms-meta">
            <span class="tms-muted">Organization:</span>
            <a asp-controller="Organizations" asp-action="Details" asp-route-id="@Model.OrganizationId" class="tms-badge tms-badge--link">@Model.Organization?.Name</a>
        </div>
        <div class="tms-toolbar">
            <a asp-controller="Projects" asp-action="Index" asp-route-teamId="@Model.Id" class="btn btn-outline-primary">View projects</a>
            @if (canManage)
            {
                <a asp-controller="Projects" asp-action="Create" asp-route-teamId="@Model.Id" class="btn btn-primary">Add project</a>
            }
        </div>
    </header>

    <hr class="tms-divider" />

    <div class="tms-card">
        <h2 class="tms-card__title">Members</h2>
        @if (!(Model.Members?.Any() ?? false))
        {
            <p class="tms-muted mb-0">No team members listed.</p>
        }
        else
        {
            <ul class="tms-list">
                @foreach (var m in Model.Members ?? Array.Empty<TeamManagementSystem.Web.Models.TeamMembership>())
                {
                    <li class="tms-list-item">@(m.User?.FullName ?? m.User?.Email ?? m.UserId)</li>
                }
            </ul>
        }
    </div>
</div>
